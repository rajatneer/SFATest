<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SFA Auth</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="sfa-login-shell">
        <aside class="sfa-login-left-pane">
            <div class="sfa-login-left-orbits"></div>

            <div class="sfa-login-left-top">
                <div class="sfa-login-brand-mark">S</div>
                <div>
                    <div class="sfa-login-brand-title">FieldForce SFA</div>
                    <div class="sfa-login-brand-subtitle">FMCG Sales Force Automation</div>
                </div>
            </div>

            <div class="sfa-login-left-middle">
                <h1 class="sfa-login-left-heading">Empower your field<br />sales team</h1>
                <div class="sfa-login-feature-list">
                    <div class="sfa-login-feature-item">
                        <div class="sfa-login-feature-icon">GPS</div>
                        <div>
                            <div class="sfa-login-feature-title">GPS-Verified Check-ins</div>
                            <div class="sfa-login-feature-description">Geo-validated customer visits with tolerance control</div>
                        </div>
                    </div>
                    <div class="sfa-login-feature-item">
                        <div class="sfa-login-feature-icon">ORD</div>
                        <div>
                            <div class="sfa-login-feature-title">Offline-First Orders</div>
                            <div class="sfa-login-feature-description">Capture orders even without network. Sync when online.</div>
                        </div>
                    </div>
                    <div class="sfa-login-feature-item">
                        <div class="sfa-login-feature-icon">ANA</div>
                        <div>
                            <div class="sfa-login-feature-title">Real-Time Analytics</div>
                            <div class="sfa-login-feature-description">Route coverage, strike rates, and distributor tracking</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="sfa-login-left-footer">&copy; 2026 FieldForce SFA. All rights reserved.</div>
        </aside>

        <main class="sfa-login-right-pane">
            <div class="sfa-login-right-inner">
                <div class="sfa-login-mobile-brand">
                    <div class="sfa-login-brand-mark">S</div>
                    <div class="sfa-login-brand-title-mobile">FieldForce SFA</div>
                </div>
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>