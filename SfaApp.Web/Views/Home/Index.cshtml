@model DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Sales Force Automation</h1>
        <p class="text-muted mb-0">Operational overview for current day.</p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <p class="text-muted mb-1">Active Customers</p>
                <h2 class="h3 mb-0">@Model.CustomerCount</h2>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <p class="text-muted mb-1">Active Products</p>
                <h2 class="h3 mb-0">@Model.ProductCount</h2>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <p class="text-muted mb-1">Pending Approvals</p>
                <h2 class="h3 mb-0">@Model.PendingApprovalCount</h2>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <p class="text-muted mb-1">Today's Visits / Orders</p>
                <h2 class="h3 mb-0">@Model.TodaysVisitCount / @Model.TodaysOrderCount</h2>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <h3 class="h5">Quick Actions</h3>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary" asp-controller="Customers" asp-action="Create">New Customer</a>
            <a class="btn btn-outline-primary" asp-controller="Products" asp-action="Create">New Product</a>
            <a class="btn btn-outline-primary" asp-controller="Visits" asp-action="Create">Log Visit</a>
            <a class="btn btn-outline-primary" asp-controller="Orders" asp-action="Create">Create Order</a>
        </div>
    </div>
</div>
