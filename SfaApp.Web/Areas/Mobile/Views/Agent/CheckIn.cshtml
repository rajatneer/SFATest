@model CheckInViewModel

@{
    ViewData["Title"] = "Check-In";
}

<section class="sfa-mobile-card">
    <h1 class="h5 mb-2">Check-In / Coordinate Capture</h1>

    <form asp-action="CheckIn" method="post" data-auto-geolocation="true" data-lat-field="DeviceLat" data-lng-field="DeviceLong" data-offline-enabled="true" data-offline-entity="CheckIn">
        <input asp-for="CustomerId" type="hidden" />
        <div class="mb-2">
            <label asp-for="DeviceLat" class="form-label"></label>
            <input asp-for="DeviceLat" class="form-control" type="number" step="0.0000001" readonly placeholder="Auto latitude" />
            <span asp-validation-for="DeviceLat" class="text-danger"></span>
        </div>
        <div class="mb-2">
            <label asp-for="DeviceLong" class="form-label"></label>
            <input asp-for="DeviceLong" class="form-control" type="number" step="0.0000001" readonly placeholder="Auto longitude" />
            <span asp-validation-for="DeviceLong" class="text-danger"></span>
        </div>
        <div class="mb-2 small text-muted" data-geo-status>Location will be captured automatically on submit.</div>
        <div class="mb-2 small text-muted" data-offline-status></div>
        <div class="form-check mb-3">
            <input asp-for="CaptureCustomerCoordinates" class="form-check-input" />
            <label asp-for="CaptureCustomerCoordinates" class="form-check-label">Capture coordinates if missing</label>
        </div>
        <button class="sfa-btn sfa-btn-primary w-100" type="submit">Submit Check-In</button>
    </form>
</section>