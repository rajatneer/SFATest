@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityRole>

@{
    ViewData["Title"] = "Role Management";
}

<section class="sfa-panel p-3 p-md-4 mb-3">
    <h2 class="h4 mb-2">Role Management</h2>

    <div class="sfa-section-title">Add Role</div>
    <div class="sfa-soft-block">
        <form asp-area="Admin" asp-controller="Roles" asp-action="Create" method="post" class="d-flex gap-2 flex-wrap">
            <input class="form-control" style="max-width: 320px;" name="roleName" placeholder="Role name" required />
            <button class="sfa-btn sfa-btn-primary" type="submit">Save</button>
        </form>
    </div>
</section>

<section class="sfa-panel p-3 p-md-4">
    <div class="sfa-section-title">Roles</div>
    <ul class="list-group list-group-flush">
        @foreach (var role in Model)
        {
            <li class="list-group-item px-2">@role.Name</li>
        }
    </ul>
</section>