@model IEnumerable<UploadJob>

@{
    ViewData["Title"] = "Upload Jobs";
    var uploadTypes = ViewBag.UploadTypes as IEnumerable<string> ?? [];
}

<section class="sfa-panel p-3 p-md-4 mb-3">
    <h2 class="h4 mb-2">Upload Jobs</h2>
    <p class="sfa-page-subtitle">Templates, validation, preview, and commit flow can attach to this queue.</p>

    <div class="sfa-section-title">Create Upload Job</div>
    <div class="sfa-soft-block">
        <form asp-area="Admin" asp-controller="Uploads" asp-action="Create" method="post" enctype="multipart/form-data" class="row g-2">
            <div class="col-md-5">
                <select class="form-select" name="UploadType" required>
                    @foreach (var uploadType in uploadTypes)
                    {
                        <option value="@uploadType">@uploadType</option>
                    }
                </select>
            </div>
            <div class="col-md-5"><input class="form-control" type="file" name="UploadFile" required /></div>
            <div class="col-md-2"><button class="sfa-btn sfa-btn-primary w-100" type="submit">Queue</button></div>
        </form>
        <div class="form-text mt-2">Allowed file extensions: .csv, .xlsx. Queue is processed in background.</div>
    </div>
</section>

<section class="sfa-panel p-3 p-md-4">
    <div class="table-responsive sfa-table-wrap">
        <table class="table mb-0 sfa-table">
            <thead><tr><th>Type</th><th>File</th><th>Status</th><th>Uploaded At (UTC)</th><th>Error</th></tr></thead>
            <tbody>
            @foreach (var job in Model)
            {
                <tr>
                    <td>@job.UploadType</td>
                    <td>@job.FileName</td>
                    <td>@job.Status</td>
                    <td>@job.UploadedAtUtc.ToString("dd-MMM-yyyy HH:mm")</td>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(job.ErrorFilePath))
                        {
                            <a class="sfa-btn sfa-btn-ghost"
                               asp-area="Admin"
                               asp-controller="Uploads"
                               asp-action="DownloadError"
                               asp-route-id="@job.Id">Download Error Report</a>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>