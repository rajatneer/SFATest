PORT=8080
NODE_ENV=development

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=sfa_app
MYSQL_USER=root
MYSQL_PASSWORD=ChangeMe123!
MYSQL_CONNECTION_LIMIT=10

JWT_SECRET=replace_with_long_secret
JWT_EXPIRES_IN=8h

OBJECT_STORAGE_DRIVER=local
OBJECT_STORAGE_BUCKET=sfa-files
LOCAL_OBJECT_STORAGE_PATH=./storage

# Set these only when OBJECT_STORAGE_DRIVER=s3
S3_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# Optional Redis cache
REDIS_URL=